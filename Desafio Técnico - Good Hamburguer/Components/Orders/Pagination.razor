<div class="pagination-shell d-flex justify-content-between align-items-center mt-2">
    <small>Página @Page de @Math.Max(TotalPages, 1)</small>
    <div class="d-flex gap-2">
        <button class="btn btn-sm btn-outline-secondary"
                @onclick="PreviousAsync"
                disabled="@IsPreviousDisabled">
            Anterior
        </button>
        <button class="btn btn-sm btn-primary"
                @onclick="NextAsync"
                disabled="@IsNextDisabled">
            Próxima
        </button>
    </div>
</div>

@code {
    [Parameter] public int Page { get; set; }
    [Parameter] public int TotalPages { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter, EditorRequired] public EventCallback<int> OnPageChanged { get; set; }

    private bool IsPreviousDisabled => Disabled || Page <= 1;
    private bool IsNextDisabled => Disabled || TotalPages == 0 || Page >= TotalPages;

    private async Task PreviousAsync()
    {
        if (IsPreviousDisabled)
        {
            return;
        }

        await OnPageChanged.InvokeAsync(Page - 1);
    }

    private async Task NextAsync()
    {
        if (IsNextDisabled)
        {
            return;
        }

        await OnPageChanged.InvokeAsync(Page + 1);
    }
}
