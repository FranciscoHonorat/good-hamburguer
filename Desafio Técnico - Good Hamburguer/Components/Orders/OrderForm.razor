@using System.Linq

<section class="card order-form-card">
    <div class="card-header d-flex justify-content-between align-items-center gap-2">
        <span>@(ViewModel.IsEditing ? "Editar pedido" : "Novo pedido")</span>
        <span class="selection-count">@SelectedItems.Count item(ns) selecionado(s)</span>
    </div>
    <div class="card-body">
        @if (MenuItems.Count == 0)
        {
            <div class="state-message state-message--soft mb-3">
                <p class="state-message-title mb-1">@(IsMenuLoading ? "Carregando opções do cardápio..." : "Nenhum item de cardápio disponível")</p>
                <p class="state-message-subtitle mb-0">@(IsMenuLoading ? "Aguarde alguns instantes para continuar." : "Atualize a tela em alguns instantes.")</p>
            </div>
        }

        <div class="row g-3">
            @foreach (var item in MenuItems)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="menu-option @(IsSelected(item.Code) ? "is-selected" : null)">
                        <input class="form-check-input"
                               type="checkbox"
                               id="item-@item.Code"
                               checked="@IsSelected(item.Code)"
                               @onchange="@(e => ToggleItem(item.Code, e.Value is bool isChecked && isChecked))"
                               disabled="@IsBusy" />
                        <label class="form-check-label menu-option-label" for="item-@item.Code">
                            <span class="menu-option-name">@item.Name</span>
                            <span class="menu-option-code">@item.Code</span>
                            <span class="menu-option-category">@item.Category</span>
                            <span class="menu-option-price">R$ @item.Price.ToString("0.00")</span>
                        </label>
                    </div>
                </div>
            }
        </div>

        @if (SelectedItems.Count > 0)
        {
            <div class="totals-grid mt-3">
                <div class="total-box">
                    <small>Subtotal estimado</small>
                    <strong>R$ @EstimatedSubtotal.ToString("0.00")</strong>
                </div>
                <div class="total-box">
                    <small>Desconto</small>
                    <strong>Automático</strong>
                </div>
                <div class="total-box total-box--accent">
                    <small>Total estimado</small>
                    <strong>R$ @EstimatedSubtotal.ToString("0.00")</strong>
                </div>
            </div>
            <small class="d-block mt-2 text-muted">Combos e descontos são aplicados automaticamente pela API ao salvar o pedido.</small>
        }

        <div class="mt-3 d-flex flex-wrap gap-2">
            <button class="btn btn-primary" @onclick="OnSubmit" disabled="@(!CanSubmit)">
                @(IsBusy ? "Salvando..." : ViewModel.IsEditing ? "Salvar edição" : "Criar pedido")
            </button>
            <button class="btn btn-outline-secondary" @onclick="Reset" disabled="@(!CanReset)">Limpar</button>
            @if (ViewModel.IsEditing)
            {
                <button class="btn btn-outline-dark" @onclick="OnCancel" disabled="@IsBusy">Cancelar edição</button>
            }
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public required CreateOrderViewModel ViewModel { get; set; }
    [Parameter, EditorRequired] public required IReadOnlyList<MenuItemResponse> MenuItems { get; set; }
    [Parameter] public bool IsMenuLoading { get; set; }
    [Parameter] public bool IsBusy { get; set; }
    [Parameter, EditorRequired] public EventCallback OnSubmit { get; set; }
    [Parameter, EditorRequired] public EventCallback OnCancel { get; set; }

    private IReadOnlyList<MenuItemResponse> SelectedItems
        => MenuItems.Where(x => IsSelected(x.Code)).ToList();

    private decimal EstimatedSubtotal
        => SelectedItems.Sum(x => x.Price);

    private bool CanSubmit
        => !IsBusy && MenuItems.Count > 0 && SelectedItems.Count > 0;

    private bool CanReset
        => !IsBusy && (SelectedItems.Count > 0 || ViewModel.IsEditing);

    private bool IsSelected(string code)
        => ViewModel.SelectedItemCodes.Contains(code, StringComparer.OrdinalIgnoreCase);

    private void ToggleItem(string code, bool selected)
    {
        if (IsBusy)
        {
            return;
        }

        if (selected)
        {
            AddSelectedCode(code);

            return;
        }

        ViewModel.SelectedItemCodes.RemoveAll(x => string.Equals(x, code, StringComparison.OrdinalIgnoreCase));
    }

    private void AddSelectedCode(string code)
    {
        if (!ViewModel.SelectedItemCodes.Contains(code, StringComparer.OrdinalIgnoreCase))
        {
            ViewModel.SelectedItemCodes.Add(code);
        }
    }

    private void Reset()
        => ViewModel.ResetSelection();
}
