@page "/cardapio"
@inject MenuApiClient MenuApiClient
@inject ILogger<Cardapio> Logger

<PageTitle>Cardápio</PageTitle>

<section class="page-header">
    <h1>Cardápio</h1>
    <p>Itens disponíveis para montagem de pedidos.</p>
</section>

<FeedbackAlert Message="@_feedback.ErrorMessage" CssClass="alert-danger" />

@if (_loadState.IsBusy)
{
    <p>Carregando cardápio...</p>
}
else
{
    <div class="row g-3">
        @foreach (var item in _items)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 menu-item-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                            <h5 class="card-title mb-0">@item.Name</h5>
                            <span class="menu-category">@item.Category</span>
                        </div>
                        <div class="menu-code">Código: @item.Code</div>
                        <div class="menu-price">R$ @item.Price.ToString("0.00")</div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private IReadOnlyList<MenuItemResponse> _items = [];
    private readonly BusyState _loadState = new();
    private readonly FeedbackState _feedback = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _loadState.Start();
            _items = await MenuApiClient.GetMenuAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Falha ao carregar cardápio");
            _feedback.SetError(ex.Message);
        }
        finally
        {
            _loadState.Stop();
        }
    }
}
