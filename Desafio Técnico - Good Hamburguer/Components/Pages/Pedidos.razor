@page "/pedidos"
@inject MenuApiClient MenuApiClient
@inject OrdersApiClient OrdersApiClient
@inject ILogger<Pedidos> Logger

<PageTitle>Pedidos</PageTitle>

<section class="page-header">
    <h1>Pedidos</h1>
    <p>Crie pedidos com seleção rápida de itens e acompanhe os resultados com paginação.</p>
</section>

<FeedbackAlert Message="@_viewModel.Feedback.ErrorMessage" CssClass="alert-danger" />
<FeedbackAlert Message="@_viewModel.Feedback.SuccessMessage" CssClass="alert-success" />

<div class="orders-page-stack">
    <OrderForm
        ViewModel="_viewModel"
        MenuItems="_menuItems"
        IsMenuLoading="_menuLoadState.IsBusy"
        IsBusy="@IsFormBusy"
        OnSubmit="SubmitOrderAsync"
        OnCancel="CancelEdit" />

    <OrdersTable
        Orders="_orders.Items"
        IsLoading="_ordersLoadState.IsBusy"
        IsActionInProgress="_viewModel.SubmitState.IsBusy"
        OnRefresh="RefreshOrdersAsync"
        OnEdit="StartEdit"
        OnDelete="DeleteOrderAsync" />

    <Pagination
        Page="_page"
        TotalPages="_orders.TotalPages"
        Disabled="@IsPageBusy"
        OnPageChanged="ChangePageAsync" />
</div>

@code {
    private IReadOnlyList<MenuItemResponse> _menuItems = [];
    private readonly CreateOrderViewModel _viewModel = new();
    private PaginatedResponse<OrderResponse> _orders = new()
    {
        Items = [],
        Page = 1,
        PageSize = 10,
        TotalItems = 0,
        TotalPages = 0
    };

    private int _page = 1;
    private const int PageSize = 10;
    private readonly BusyState _menuLoadState = new();
    private readonly BusyState _ordersLoadState = new();

    private bool IsFormBusy => _viewModel.SubmitState.IsBusy || _menuLoadState.IsBusy;
    private bool IsPageBusy => _ordersLoadState.IsBusy || _viewModel.SubmitState.IsBusy;

    protected override async Task OnInitializedAsync()
    {
        await LoadMenuAsync();
        await LoadOrdersAsync();
    }

    private async Task SubmitOrderAsync()
    {
        await ExecuteSubmitActionAsync(async () =>
        {
            var request = _viewModel.ToRequest();

            if (_viewModel.EditingOrderId is { } editingOrderId)
            {
                await OrdersApiClient.UpdateOrderAsync(editingOrderId, request);
                _viewModel.Feedback.SetSuccess("Pedido atualizado com sucesso.");
            }
            else
            {
                await OrdersApiClient.CreateOrderAsync(request);
                _viewModel.Feedback.SetSuccess("Pedido criado com sucesso.");
            }

            _viewModel.ResetSelection();
            _page = 1;
            await LoadOrdersAsync(clearFeedback: false);
        }, "Falha ao salvar pedido");
    }

    private async Task DeleteOrderAsync(Guid id)
    {
        await ExecuteSubmitActionAsync(async () =>
        {
            await OrdersApiClient.DeleteOrderAsync(id);
            _viewModel.Feedback.SetSuccess("Pedido excluído com sucesso.");

            if (_orders.Items.Count == 1 && _page > 1)
            {
                _page--;
            }

            await LoadOrdersAsync(clearFeedback: false);
        }, "Falha ao excluir pedido");
    }

    private async Task LoadMenuAsync()
        => await ExecuteLoadActionAsync(
            _menuLoadState,
            async () => _menuItems = await MenuApiClient.GetMenuAsync(),
            "Falha ao carregar menu na tela de pedidos");

    private async Task LoadOrdersAsync(bool clearFeedback = true)
        => await ExecuteLoadActionAsync(
            _ordersLoadState,
            async () => _orders = await OrdersApiClient.GetOrdersAsync(_page, PageSize),
            "Falha ao carregar pedidos",
            clearFeedback);

    private void StartEdit(OrderResponse order)
        => _viewModel.StartEditing(order);

    private void CancelEdit() => _viewModel.ResetSelection();

    private async Task ExecuteSubmitActionAsync(Func<Task> action, string errorLogMessage)
    {
        _viewModel.Feedback.Clear();

        try
        {
            await _viewModel.SubmitState.ExecuteAsync(action);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, errorLogMessage);
            _viewModel.Feedback.SetError(ex.Message);
        }
    }

    private async Task ExecuteLoadActionAsync(BusyState state, Func<Task> action, string errorLogMessage, bool clearFeedback = false)
    {
        if (clearFeedback)
        {
            _viewModel.Feedback.Clear();
        }

        try
        {
            await state.ExecuteAsync(action);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, errorLogMessage);
            _viewModel.Feedback.SetError(ex.Message);
        }
    }

    private async Task ChangePageAsync(int page)
    {
        _page = page;
        await LoadOrdersAsync();
    }

    private Task RefreshOrdersAsync() => LoadOrdersAsync();
}
