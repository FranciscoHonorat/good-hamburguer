# Regras globais do repositório

# Build artifacts (.NET / Blazor)
**/bin/
**/obj/
.vs/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# IDEs
.idea/
.vscode/

# Frontend artifacts
node_modules/
dist/
build/
coverage/

# Logs and temporary files
*.log
logs/
*.tmp
*.temp
test-output.txt

# Environment and secrets
.env
.env.*
!.env.example
!.env.sample

# App settings with local secrets
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json

# Certificates / private keys
*.pfx
*.p12
*.pem
*.key
*.crt

# Publish/deployment profiles
*.pubxml.user

# Local databases / dumps / backups
*.db
*.sqlite
*.sqlite3
*.mdf
*.ldf
*.bak
*.sql

# OS generated files
.DS_Store
Thumbs.db
